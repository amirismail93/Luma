{
  "name": "luma",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "concurrently -n \"[Luma Server],[Luma App]\" -c \"cyan,green\" \"npm run server\" \"npm run metro\"",
    "metro": "react-native start",
    "server": "cd server && npx ts-node src/index.ts",
    "android": "react-native run-android",
    "android-tv": "react-native run-android --device",
    "build-apk": "cd android && .\\gradlew assembleRelease && cd .. && node -e \"const fs=require('fs');const p='dist';if(!fs.existsSync(p))fs.mkdirSync(p);fs.copyFileSync('android/app/build/outputs/apk/release/app-release.apk',p+'/luma-release.apk');console.log('APK copied to dist/luma-release.apk');\"",
    "install-firestick": "adb install -r dist/luma-release.apk",
    "setup": "cd server && npm install && cd .. && npm install",
    "lint": "eslint .",
    "clean": "cd android && .\\gradlew clean && cd .."
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tanstack/react-query": "^5.99.2",
    "react": "18.3.1",
    "react-native": "npm:react-native-tvos@0.76.3-0",
    "react-native-mmkv": "^2.12.2",
    "react-native-safe-area-context": "^4.14.0",
    "react-native-screens": "^3.35.0",
    "react-native-video": "^6.19.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native/babel-preset": "^0.76.3",
    "@react-native/metro-config": "^0.76.3",
    "@react-native/typescript-config": "^0.76.3",
    "@types/react": "^18.3.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^8.2.2",
    "typescript": "^5.6.3"
  }
}
